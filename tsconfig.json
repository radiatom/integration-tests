{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "typeRoots": [
      "node_modules/@types",
      "src/types"
    ],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

		"noImplicitAny": false,
    "strictFunctionTypes": false,
  },
  "include": ["./src/**/*.ts", "./src/**/**/*.tsx",  "./src/**/*.tsx", "./src/**/*.json"],
  "exclude": ["node_modules"]
}